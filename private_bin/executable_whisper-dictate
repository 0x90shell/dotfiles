#!/bin/bash
set -euo pipefail

# --- Config ---
MODEL="${WHISPER_MODEL:-$HOME/.local/share/whisper/ggml-small.en.bin}"
# Uses whatever mic is currently set as default in pavucontrol/pipewire
PULSE_SOURCE="@DEFAULT_SOURCE@"
SILENCE_THRESH="3%"    # raise if it hangs, lower if it cuts early
SILENCE_DURATION="2.0" # seconds of silence before auto-stop
MAX_DURATION="120"     # hard cap in seconds (safety net)
PIDFILE="/tmp/whisper-dictate.pid"
WAVFILE="/tmp/whisper-dictate.wav"

notify() { notify-send -t 2000 "Dictate" "$1" 2>/dev/null || true; }

# --- Toggle: if already recording, stop and transcribe ---
if [[ -f "$PIDFILE" ]]; then
    PID=$(cat "$PIDFILE")
    if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        wait "$PID" 2>/dev/null || true
    fi
    rm -f "$PIDFILE"

    if [[ ! -f "$WAVFILE" || ! -s "$WAVFILE" ]]; then
        notify "No audio captured"
        rm -f "$WAVFILE"
        exit 1
    fi

    notify "Transcribing..."
    RESULT=$(whisper-cli -m "$MODEL" -f "$WAVFILE" -l en -nt -np 2>/dev/null \
        | tr '\n' ' ' | sed 's/  */ /g; s/^ *//; s/ *$//')

    rm -f "$WAVFILE"

    if [[ -z "$RESULT" ]]; then
        notify "No speech detected"
        exit 0
    fi

    echo -n "$RESULT" | xclip -selection clipboard
    notify "Copied: ${RESULT:0:80}"
    exit 0
fi

# --- Start recording ---
if [[ ! -f "$MODEL" ]]; then
    notify "Model not found: $MODEL"
    exit 1
fi

rm -f "$WAVFILE"
notify "Recording..."

# Auto-stops on silence OR max duration; manual stop via re-run
# silence 1 0.1 0% = no input gate (start immediately)
# silence 1 $DUR $THRESH = stop after DUR seconds below THRESH
AUDIODEV="pulse" PULSE_SOURCE="$PULSE_SOURCE" \
rec -q "$WAVFILE" rate 16k channels 1 \
    trim 0 "$MAX_DURATION" \
    silence 1 0.1 0% 1 "$SILENCE_DURATION" "$SILENCE_THRESH" &
REC_PID=$!
echo "$REC_PID" > "$PIDFILE"

# Wait for rec to finish on its own, then auto-transcribe
wait "$REC_PID" 2>/dev/null || true
rm -f "$PIDFILE"

if [[ ! -f "$WAVFILE" || ! -s "$WAVFILE" ]]; then
    notify "No audio captured"
    rm -f "$WAVFILE"
    exit 1
fi

notify "Transcribing..."
RESULT=$(whisper-cli -m "$MODEL" -f "$WAVFILE" -l en -nt -np 2>/dev/null \
    | tr '\n' ' ' | sed 's/  */ /g; s/^ *//; s/ *$//')

rm -f "$WAVFILE"

if [[ -z "$RESULT" ]]; then
    notify "No speech detected"
    exit 0
fi

echo -n "$RESULT" | xclip -selection clipboard
notify "Copied: ${RESULT:0:80}"
