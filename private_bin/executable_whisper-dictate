#!/bin/bash
TMPFILE=$(mktemp /tmp/dictation-XXXX.wav)

# longer silence window before stopping
rec -q "$TMPFILE" rate 16k silence 1 0.01 0% 1 3.0 1%

# transcribe
whisper "$TMPFILE" --model small.en --device cuda --output_format txt --output_dir /tmp >/dev/null 2>&1
TXTFILE="/tmp/$(basename "${TMPFILE%.wav}").txt"

if [ -f "$TXTFILE" ]; then
    RESULT=$(cat "$TXTFILE" | tr '\n' ' ' | sed 's/  */ /g; s/^ //; s/ $//')
    # copy to clipboard instead of typing
    echo -n "$RESULT" | xclip -selection clipboard
    echo "Copied to clipboard: $RESULT"
    rm -f "$TXTFILE"
fi

rm -f "$TMPFILE"
notify-send "Dictation complete"
