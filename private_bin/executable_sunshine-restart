#!/bin/bash
# Restart Sunshine from within a Moonlight session.
#
# Uses systemd-run to schedule the restart after this script exits,
# giving Moonlight time to receive the launch acknowledgment before
# the stream drops. Without this, Android Moonlight shows 503 errors.

systemctl --user reset-failed sunshine 2>/dev/null
systemctl --user stop sunshine-deferred-restart.timer 2>/dev/null
systemctl --user stop sunshine-deferred-restart.service 2>/dev/null
systemctl --user reset-failed sunshine-deferred-restart.service 2>/dev/null

# Wake the display now so it's ready by the time sunshine restarts.
"$HOME/bin/wake-display"

systemd-run --user --on-active=3s --unit=sunshine-deferred-restart \
  systemctl --user restart sunshine
