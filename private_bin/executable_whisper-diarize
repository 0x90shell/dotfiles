#!/bin/bash
set -euo pipefail

# whisper-diarize — local multi-speaker diarized transcription via whisper.cpp + sherpa-onnx
# Output: <input>.transcript.txt with [speaker_NN] tagged lines

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<'EOF'
usage: whisper-diarize <input> [num_speakers]

Local multi-speaker diarized transcription using whisper.cpp + sherpa-onnx.
Output: <input>.transcript.txt with [speaker_NN]-tagged lines, ready to paste
into an LLM for speaker inference.

Arguments:
  <input>          Audio/video file (any ffmpeg-supported format)
  [num_speakers]   Number of speakers to detect (default: 3)

Environment variables:
  WHISPER_MODEL    Whisper GGML model    (default: ~/.local/share/whisper/ggml-large-v3.bin)
  VAD_MODEL        Silero VAD model (GGML) (default: ~/.local/share/whisper/ggml-silero-v5.1.2.bin)
  SHERPA_DIR       Sherpa-onnx model dir (default: ~/.local/share/sherpa-onnx)
  DIAR_THREADS     Diarization threads   (default: min(8, nproc))

Examples:
  whisper-diarize meeting.mkv 4
  DIAR_THREADS=4 whisper-diarize call.wav
EOF
    exit 0
fi

INPUT="${1:?usage: whisper-diarize <input> [num_speakers]   (try --help)}"
NUM_SPEAKERS="${2:-3}"

if [[ ! -f "$INPUT" ]]; then
    echo "error: $INPUT not found" >&2
    exit 1
fi

WHISPER_MODEL="${WHISPER_MODEL:-$HOME/.local/share/whisper/ggml-large-v3.bin}"
VAD_MODEL="${VAD_MODEL:-$HOME/.local/share/whisper/ggml-silero-v5.1.2.bin}"
SHERPA_DIR="${SHERPA_DIR:-$HOME/.local/share/sherpa-onnx}"
SEG_MODEL="$SHERPA_DIR/sherpa-onnx-pyannote-segmentation-3-0/model.onnx"
EMB_MODEL="$SHERPA_DIR/3dspeaker_speech_eres2net_base_sv_zh-cn_3dspeaker_16k.onnx"

for f in "$WHISPER_MODEL" "$VAD_MODEL" "$SEG_MODEL" "$EMB_MODEL"; do
    [[ -f "$f" ]] || { echo "error: missing model: $f" >&2; exit 1; }
done

for cmd in ffmpeg whisper-cli sherpa-onnx-offline-speaker-diarization awk; do
    command -v "$cmd" >/dev/null || { echo "error: $cmd not on PATH" >&2; exit 1; }
done

WORKDIR="$(mktemp -d)"
trap 'rm -rf "$WORKDIR"' EXIT

WAV="$WORKDIR/audio.wav"
SRT_BASE="$WORKDIR/audio"
OUT="${INPUT%.*}.transcript.txt"

echo "[1/4] Converting to 16kHz mono WAV..."
ffmpeg -y -i "$INPUT" -ar 16000 -ac 1 -c:a pcm_s16le "$WAV" \
    -hide_banner -loglevel error

echo "[2/4] Transcribing with whisper (large-v3, VAD-gated)..."
# VAD trims silence regions before whisper sees them, killing the
# "thank you for watching" YouTube-corpus hallucination at file start.
whisper-cli -pp -m "$WHISPER_MODEL" -l en -f "$WAV" \
    --vad --vad-model "$VAD_MODEL" \
    -of "$SRT_BASE" -osrt --max-context 0 --suppress-nst >/dev/null

# Cap at 8: eres2net is small, memory-bandwidth bound past that. Override via env.
DIAR_THREADS="${DIAR_THREADS:-$(( $(nproc) > 8 ? 8 : $(nproc) ))}"
echo "[3/4] Diarizing ($NUM_SPEAKERS speakers, $DIAR_THREADS threads)..."
sherpa-onnx-offline-speaker-diarization \
    --clustering.num-clusters="$NUM_SPEAKERS" \
    --segmentation.pyannote-model="$SEG_MODEL" \
    --segmentation.num-threads="$DIAR_THREADS" \
    --embedding.model="$EMB_MODEL" \
    --embedding.num-threads="$DIAR_THREADS" \
    "$WAV" 2>/dev/null > "$WORKDIR/diar.txt"

if [[ ! -s "$WORKDIR/diar.txt" ]]; then
    echo "error: diarization produced no output" >&2
    exit 1
fi

echo "[4/4] Merging speaker labels into SRT segments..."
# For each whisper SRT segment, find the diarization speaker with the most
# time overlap and prepend [speaker_NN] to the segment text.
awk -v diar="$WORKDIR/diar.txt" '
function ts2sec(s,   p) {
    # "HH:MM:SS,mmm" -> float seconds
    split(s, p, /[:,]/)
    return p[1]*3600 + p[2]*60 + p[3] + p[4]/1000
}
BEGIN {
    # Load diar lines like: "0.031 -- 1.486 speaker_00"
    while ((getline line < diar) > 0) {
        n = split(line, f, /[ \t]+/)
        if (n >= 4 && f[2] == "--") {
            ndi++
            di_s[ndi] = f[1] + 0
            di_e[ndi] = f[3] + 0
            di_k[ndi] = f[4]
        }
    }
    close(diar)
    state = "idx"
}
state == "idx" && /^[0-9]+$/ { state = "ts"; next }
state == "ts" && / --> / {
    split($0, p, " --> ")
    seg_s = ts2sec(p[1]); seg_e = ts2sec(p[2])
    state = "text"; text = ""; next
}
state == "text" && /^[[:space:]]*$/ {
    delete ov
    for (i = 1; i <= ndi; i++) {
        a = (di_s[i] > seg_s) ? di_s[i] : seg_s
        b = (di_e[i] < seg_e) ? di_e[i] : seg_e
        if (b > a) ov[di_k[i]] += (b - a)
    }
    best = "speaker_??"; bv = 0
    for (s in ov) if (ov[s] > bv) { bv = ov[s]; best = s }
    sub(/^[[:space:]]+/, "", text); sub(/[[:space:]]+$/, "", text)
    if (text != "") printf "[%s] %s\n", best, text
    state = "idx"; next
}
state == "text" { text = (text == "" ? $0 : text " " $0) }
' "$SRT_BASE.srt" > "$OUT"

echo
echo "Done: $OUT"
wc -l "$OUT"
echo
echo "Speaker turns by ID:"
awk -F'] ' '{print $1"]"}' "$OUT" | sort | uniq -c | sort -rn
