#!/bin/bash
export DISPLAY=:0
export XAUTHORITY=$HOME/.Xauthority
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$(id -u)/bus

xfce4-screensaver-command -d
xset dpms force on
xset s reset
xdotool mousemove_relative 1 0
xdotool mousemove_relative -- -1 0

# Find the connected output dynamically.
connected_output=$(xrandr | grep -oP '^\S+ connected' | head -1 | awk '{print $1}')

# Wait for display to come online with an active mode.
# Sunshine needs "connected <resolution>" not just "connected".
display_ready=false
for i in $(seq 1 30); do
    if xrandr | grep -qE "^${connected_output:-HDMI}.* connected (primary )?[0-9]"; then
        display_ready=true
        break
    fi
    # If connected but no active mode, force one.
    if [ -n "$connected_output" ] && xrandr | grep -qP "^${connected_output} connected (\(|$)"; then
        xrandr --output "$connected_output" --auto
    fi
    sleep 0.2
done

if [ "$display_ready" = false ]; then
    echo "wake-display: display did not come online within 6s" >&2
    exit 1
fi
