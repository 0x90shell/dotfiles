{
  "apps": [
    {
      "auto-detach": true,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "/home/gandalf/.config/sunshine/assets/desktop.png",
      "name": "Desktop",
      "prep-cmd": [
        {
          "do": "/home/gandalf/bin/wake-display",
          "undo": ""
        },
        {
          "do": "/home/gandalf/bin/gamepad-resync --bg",
          "undo": ""
        }
      ],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "cmd": "/home/gandalf/bin/esdepull",
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "/home/gandalf/.config/sunshine/assets/esde.png",
      "name": "ES-DE",
      "prep-cmd": [
        {
          "do": "/home/gandalf/bin/wake-display",
          "undo": "killall es-de"
        },
        {
          "do": "/home/gandalf/bin/gamepad-resync --bg",
          "undo": ""
        }
      ],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "cmd": "perfect-dark",
      "elevated": false,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "/home/gandalf/.config/sunshine/assets/perfectdark.png",
      "name": "Perfect Dark",
      "output": "",
      "prep-cmd": [
        {
          "do": "/home/gandalf/bin/wake-display",
          "undo": ""
        },
        {
          "do": "/home/gandalf/bin/gamepad-resync --bg",
          "undo": ""
        }
      ],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "detached": [
        "setsid steam steam://open/bigpicture"
      ],
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "steam.png",
      "name": "Steam Big Picture",
      "prep-cmd": [
        {
          "do": "/home/gandalf/bin/wake-display",
          "undo": "setsid steam steam://close/bigpicture"
        },
        {
          "do": "/home/gandalf/bin/gamepad-resync --bg",
          "undo": ""
        }
      ],
      "wait-all": true
    },
    {
      "name": "Restart Sunshine",
      "image-path": "/home/gandalf/.config/sunshine/assets/restart.png",
      "cmd": "/home/gandalf/bin/sunshine-restart",
      "auto-detach": "true",
      "wait-all": "true"
    }
  ],
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  }
}
